page {
  background-color: #F5F5F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.btn-primary {
  background: #D85A30;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 32rpx;
  text-align: center;
}

.btn-secondary {
  background: #fff;
  color: #D85A30;
  border: 1px solid #D85A30;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 32rpx;
  text-align: center;
}

.text-muted {
  color: #999;
  font-size: 24rpx;
}

.text-danger {
  color: #E24B4A;
}

.badge-shared {
  background: #EAF3DE;
  color: #3B6D11;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.badge-personal {
  background: #E6F1FB;
  color: #0C447C;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
