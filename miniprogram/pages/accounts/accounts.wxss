.section-title { font-size: 26rpx; color: #888; padding: 32rpx 0 16rpx; }

.account-card { padding: 28rpx; }
.account-name { font-size: 30rpx; margin-right: 12rpx; }
.account-balance { font-size: 34rpx; font-weight: 500; color: #333; }

.add-btn { margin-top: 32rpx; }

.modal-mask {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; z-index: 999;
}
.modal-content {
  background: #fff; border-radius: 20rpx; padding: 40rpx; width: 600rpx;
}
.modal-title { font-size: 34rpx; font-weight: 500; margin-bottom: 32rpx; text-align: center; }
.modal-input {
  border: 1px solid #e0e0e0; border-radius: 12rpx; padding: 20rpx; margin-bottom: 20rpx; font-size: 28rpx;
}
.modal-type { display: flex; gap: 16rpx; margin-bottom: 32rpx; }
.type-option {
  flex: 1; text-align: center; padding: 16rpx; border-radius: 12rpx;
  border: 1px solid #e0e0e0; font-size: 28rpx; color: #666;
}
.type-option.active { border-color: #D85A30; color: #D85A30; background: #FFF5F0; }
.modal-btns { display: flex; gap: 16rpx; }
.modal-btns button { flex: 1; }
